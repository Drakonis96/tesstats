    "That file isn't a valid Tesstats backup.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "That file isn't a valid Tesstats backup."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ese archivo no es una copia válida de Tesstats."
          }
        }
      }
    },
    "The backup holds your server settings and credentials, locked with a password only you know — AES-256 encrypted. Keep the password safe: it can't be recovered.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The backup holds your server settings and credentials, locked with a password only you know — AES-256 encrypted. Keep the password safe: it can't be recovered."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La copia contiene la configuración del servidor y las credenciales, protegidas con una contraseña que solo tú conoces — cifrada con AES-256. Guarda bien la contraseña: no se puede recuperar."
          }
        }
      }
    },
    "The backup includes your server settings and credentials so a second device can be set up without retyping. Keep it private.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The backup includes your server settings and credentials so a second device can be set up without retyping. Keep it private."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La copia incluye la configuración del servidor y las credenciales para configurar otro dispositivo sin volver a teclear. Mantenla privada."
          }
        }
      }
    },
    "The car is showing the Sentry banner (center display state 7) near %@. This is inferred — any clip is on the car's USB and isn't available via TeslaMate.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The car is showing the Sentry banner (center display state 7) near %@. This is inferred — any clip is on the car's USB and isn't available via TeslaMate."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El coche muestra el aviso de Sentry (estado de pantalla 7) cerca de %@. Es una inferencia: cualquier clip está en el USB del coche y no está disponible vía TeslaMate."
          }
        }
      }
    },
    "This backup is password-protected. Enter its password to restore.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
