# --- MQTT (same broker TeslaMate uses) ---
# Inside the same docker network you can talk to mosquitto directly (no TLS needed):
MQTT_URL=mqtt://mosquitto:1883
MQTT_USERNAME=tesstats
MQTT_PASSWORD=change-me
# If instead you reach it over wss behind a reverse proxy with Basic Auth:
# MQTT_URL=wss://teslamqtt.example.com/
# MQTT_BASIC_AUTH=user:pass
TOPIC_ROOT=teslamate/cars

# --- HTTP (device-token registration endpoint) ---
PORT=8090
# Shared secret the app must include when registering its push token (recommended).
REGISTER_TOKEN=choose-a-long-random-string

# --- APNs (Apple Push Notification service) ---
# Create an APNs Auth Key (.p8) in the Apple Developer portal (Keys → +, enable APNs).
APNS_KEY_PATH=/keys/AuthKey_ABCDE12345.p8
APNS_KEY_ID=ABCDE12345
APNS_TEAM_ID=YOURTEAMID
APNS_BUNDLE_ID=com.tesstats.app
# false = sandbox (development builds), true = production (TestFlight/App Store)
APNS_PRODUCTION=false

# --- Which events trigger an immediate push ---
NOTIFY_SENTRY=true
NOTIFY_UNLOCKED=true
NOTIFY_OPENINGS=true
